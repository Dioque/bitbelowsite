## import HeaderLink from './HeaderLink.astro';

<header>
	<nav>
		<div class="logo">
			<a href="/">
				BitBelow
			</a>
		</div>

```
	<div class="menu">
		<HeaderLink href="/">Inicio</HeaderLink>
		<HeaderLink href="/games">Jogos</HeaderLink>
		<HeaderLink href="/about">Estudio</HeaderLink>
		<HeaderLink href="/contact">Contato</HeaderLink>
	</div>

	<div class="social">
		<a href="https://github.com/" target="_blank">
			GitHub
		</a>
	</div>
</nav>
```

</header>

<style>

header{
	position:sticky;
	top:0;
	z-index:1000;

	background:#111111;
	border-bottom:1px solid rgba(255,122,0,.15);
}

nav{
	max-width:1200px;
	margin:auto;

	display:flex;
	align-items:center;
	justify-content:space-between;

	padding:1rem 2rem;
}

.logo a{
	color:#ff7a00;
	font-size:1.5rem;
	font-weight:800;
	text-decoration:none;
	letter-spacing:1px;
}

.menu{
	display:flex;
	gap:2rem;
}

.menu a{
	color:white;
	text-decoration:none;
	font-weight:600;

	transition:.2s;
}

.menu a:hover{
	color:#ff7a00;
}

.social a{
	color:#ff7a00;
	text-decoration:none;
	font-weight:700;
}

@media(max-width:768px){

	nav{
		flex-direction:column;
		gap:1rem;
	}

	.menu{
		flex-wrap:wrap;
		justify-content:center;
		gap:1rem;
	}
}

</style>
