---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
</head>

<body>
	<Header />

	<main>

		<section class="hero">
			<div class="hero-content">
				<h1>BITBELOW GAME STUDIO</h1>

				<p>
					Criando experiencias memoraveis atraves de jogos independentes,
					historias envolventes e mundos unicos.
				</p>

				<div class="buttons">
					<a href="#games" class="btn-primary">Nossos Jogos</a>
					<a href="#about" class="btn-secondary">Sobre Nos</a>
				</div>
			</div>
		</section>

		<section id="games" class="games">
			<h2>Jogos em Desenvolvimento</h2>

			<div class="game-card">
				<h3>Happy Healthy</h3>

				<p>
					Um jogo de terror e sobrevivencia ambientado em uma
					clinica misteriosa onde nem tudo e o que parece.
				</p>

				<a href="/games/happy-healthy">
					Saiba Mais
				</a>
			</div>
		</section>

		<section id="about" class="about">
			<h2>Sobre a BitBelow</h2>

			<p>
				A BitBelow e um estudio independente focado no desenvolvimento
				de experiencias unicas, explorando horror, narrativa,
				exploracao e mecanicas inovadoras.
			</p>
		</section>

	</main>

	<Footer />
</body>
</html>

<style>

:root{
	--primary:#ff7a00;
	--primary-dark:#d86300;
	--bg:#111111;
	--surface:#1b1b1b;
	--text:#ffffff;
	--muted:#bdbdbd;
}

body{
	background:var(--bg);
	color:var(--text);
	margin:0;
	font-family:Arial, Helvetica, sans-serif;
}

.hero{
	min-height:80vh;
	display:flex;
	align-items:center;
	justify-content:center;
	text-align:center;
	padding:2rem;
	background:
	linear-gradient(
		180deg,
		rgba(255,122,0,.15),
		rgba(0,0,0,.8)
	);
}

.hero h1{
	font-size:4rem;
	color:var(--primary);
	margin-bottom:1rem;
}

.hero p{
	max-width:700px;
	margin:auto;
	font-size:1.2rem;
	color:var(--muted);
}

.buttons{
	margin-top:2rem;
	display:flex;
	gap:1rem;
	justify-content:center;
	flex-wrap:wrap;
}

.btn-primary,
.btn-secondary{
	padding:1rem 2rem;
	text-decoration:none;
	border-radius:8px;
	font-weight:bold;
	transition:.3s;
}

.btn-primary{
	background:var(--primary);
	color:white;
}

.btn-primary:hover{
	background:var(--primary-dark);
}

.btn-secondary{
	border:2px solid var(--primary);
	color:var(--primary);
}

.games{
	padding:5rem 2rem;
	max-width:1200px;
	margin:auto;
}

.games h2{
	text-align:center;
	margin-bottom:3rem;
}

.game-card{
	background:var(--surface);
	padding:2rem;
	border-radius:12px;
	border:1px solid rgba(255,122,0,.2);
	max-width:600px;
	margin:auto;
}

.game-card h3{
	color:var(--primary);
}

.game-card a{
	display:inline-block;
	margin-top:1rem;
	color:var(--primary);
	text-decoration:none;
	font-weight:bold;
}

.about{
	padding:5rem 2rem;
	max-width:1000px;
	margin:auto;
	text-align:center;
}

@media(max-width:768px){

	.hero h1{
		font-size:2.5rem;
	}

	.hero p{
		font-size:1rem;
	}
}

</style>
